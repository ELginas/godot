{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Project",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/bin/godot.linuxbsd.editor.dev.x86_64.llvm",
      "args": [
        "--editor",
        "--path",
        "/home/user/godot/godot-warehouse"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "preLaunchTask": "build"
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": false,
      "cwd": "/home/user/Downloads/godot/scene/main",
      "program": "/home/user/Downloads/godot/scene/main/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}